{
  "name": "mandarincourse",
  "version": "1.0.0",
  "description": "MandarinCourse — AI-Powered Chinese Learning App",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/build.mjs && NODE_ENV=production node server.js",
    "dev": "node server.js",
    "build": "node scripts/build.mjs",
    "dev:https": "NODE_EXTRA_CA_CERTS= node -e \"process.env.HTTPS='true'; require('./server.js')\""
  },
  "dependencies": {
    "@capacitor/android": "^7.6.8",
    "@capacitor/ios": "^7.6.8",
    "acorn": "^8.17.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jimp": "^1.6.1",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "ffmpeg-static": "^5.3.0"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
