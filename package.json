{
  "name": "mandarincourse",
  "version": "1.0.0",
  "description": "MandarinCourse — AI-Powered Chinese Learning App",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/build.mjs && NODE_ENV=production node server.js",
    "dev": "node server.js",
    "build": "node scripts/build.mjs",
    "dev:https": "NODE_EXTRA_CA_CERTS= node -e \"process.env.HTTPS='true'; require('./server.js')\""
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
}
